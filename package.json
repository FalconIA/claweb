{
  "name": "claweb",
  "version": "0.2.3-dev",
  "private": true,
  "type": "module",
  "description": "OpenClaw client-facing channel plugin with browser reference client and frontdoor reference host",
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "claweb",
      "label": "CLAWeb",
      "blurb": "WebSocket bridge that routes browser messages through OpenClaw."
    },
    "compat": {
      "pluginApi": ">=2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.4.15"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "pack:release": "pnpm pack --pack-destination releases/"
  },
  "dependencies": {
    "openclaw": "^2026.4.15",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/ws": "^8.5.14",
    "prettier": "^3.5.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
