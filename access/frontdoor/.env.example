# CLAWeb frontdoor — example env file
# Copy to config/.env (or .env) and fill in your values.
# Shell environment variables always take priority over this file.

# --- Server ---
# PORT=18081
# BIND=127.0.0.1

# --- Upstream CLAWeb WebSocket ---
# CLAWEB_UPSTREAM_WS=ws://127.0.0.1:18999
# CLAWEB_UPSTREAM_TOKEN=your-upstream-token
# Or load the token from a file:
# CLAWEB_UPSTREAM_TOKEN_FILE=/run/secrets/upstream_token

# --- Auth mode ---
# Passphrase mode (default — leave CLAWEB_OAUTH2_ENABLED unset or false):
#
#   Option A: point to a JSON config file
#   CLAWEB_LOGIN_CONFIG=./config/claweb-login.example.json
#
#   Option B: define users inline via env vars (merged on top of the JSON file;
#             env vars win on key collision).
#             Each slot N (1, 2, …) defines one user:
#
# CLAWEB_LOGIN_1_NAME=alice
# CLAWEB_LOGIN_1_DISPLAY_NAME=Alice
# CLAWEB_LOGIN_1_PASSPHRASE=alice-passphrase
# CLAWEB_LOGIN_1_USER_ID=user-alice
# CLAWEB_LOGIN_1_ROOM_ID=main
# CLAWEB_LOGIN_1_CLIENT_ID=client-alice
#
# CLAWEB_LOGIN_2_NAME=bob
# CLAWEB_LOGIN_2_DISPLAY_NAME=Bob
# CLAWEB_LOGIN_2_PASSPHRASE=bob-passphrase
# CLAWEB_LOGIN_2_USER_ID=user-bob
# CLAWEB_LOGIN_2_ROOM_ID=main
# CLAWEB_LOGIN_2_CLIENT_ID=client-bob
#
#   Use _PASSPHRASES (comma-separated) to assign multiple passphrases to one user:
# CLAWEB_LOGIN_1_PASSPHRASES=pass-a,pass-b
#
# OAuth2 ROPC mode:
CLAWEB_OAUTH2_ENABLED=true

# --- OAuth2 ---
CLAWEB_OAUTH2_CLIENT_ID=your-client-id
CLAWEB_OAUTH2_CLIENT_SECRET=your-client-secret
# Or load the secret from a file:
# CLAWEB_OAUTH2_CLIENT_SECRET_FILE=/run/secrets/oauth2_client_secret

CLAWEB_OAUTH2_TOKEN_URL=https://auth.example.com/oauth/token
# Fetch userinfo from a dedicated endpoint:
# CLAWEB_OAUTH2_USERINFO_URL=https://auth.example.com/oauth/userinfo
# Or read userinfo from a field embedded in the token response:
# CLAWEB_OAUTH2_USERINFO_IN_TOKEN=user_info

# Field in the userinfo object to use as the unique user identity (default: sub)
# CLAWEB_OAUTH2_USERINFO_ID_FIELD=sub
# Field to use as the display name (default: name)
# CLAWEB_OAUTH2_USERINFO_NAME_FIELD=name

# Optional scope(s) to request
# CLAWEB_OAUTH2_SCOPE=openid profile

# Token introspection — re-validates active sessions periodically
# CLAWEB_OAUTH2_INTROSPECT_URL=https://auth.example.com/oauth/check_token
# CLAWEB_OAUTH2_INTROSPECT_TTL=60

# Optional: assign all OAuth2 users to a fixed room / client-id prefix
# CLAWEB_OAUTH2_DEFAULT_ROOM_ID=main
# CLAWEB_OAUTH2_DEFAULT_CLIENT_ID_PREFIX=
